<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="top"
    android:minHeight="@dimen/spacing_48"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/spacing_12">

    <TextView
        android:id="@+id/tvMethodStepNumber"
        style="@style/StyleCategoryTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_8"
        tools:text="1." />

    <TextView
        android:id="@+id/tvMethodStepText"
        style="@style/StyleCategoryDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_primary"
        tools:text="В глубокой миске смешайте говяжий фарш, лук, чеснок, соль и перец. Разделите фарш на 4 равные части и сформируйте котлеты." />

</LinearLayout>
